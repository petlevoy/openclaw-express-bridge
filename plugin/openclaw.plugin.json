{
  "id": "openclaw-express",
  "name": "eXpress",
  "description": "eXpress channel plugin (BotX or official Linux desktop bridge)",
  "version": "2.2.4",
  "channels": ["express"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "express": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "name": { "type": "string" },
          "mode": { "type": "string", "enum": ["botx", "desktop"] },
          "botId": { "type": "string" },
          "secretKey": { "type": "string" },
          "ctsUrl": { "type": "string" },
          "markdown": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tables": {
                "type": "string",
                "enum": ["off", "code", "block", "bullets"]
              }
            }
          },
          "actions": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                { "type": "boolean" },
                {
                  "type": "string",
                  "enum": ["pairing", "allowlist", "open"]
                }
              ]
            }
          },
          "webhookPort": {
            "type": "integer",
            "minimum": 1,
            "description": "Deprecated compatibility field; BotX inbound is disabled"
          },
          "dmPolicy": {
            "type": "string",
            "enum": ["pairing", "allowlist", "open", "disabled"]
          },
          "allowFrom": { "type": "array", "items": { "type": "string" } },
          "streamMode": {
            "type": "string",
            "enum": ["off", "partial", "block"]
          },
          "mediaMaxMb": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 100
          },
          "textChunkLimit": { "type": "integer", "minimum": 1 },
          "desktopCdpUrl": { "type": "string" },
          "desktopChatId": { "type": "string", "format": "uuid" },
          "desktopChatTitle": { "type": "string", "minLength": 1 },
          "desktopSenderId": { "type": "string", "format": "uuid" },
          "desktopSenderName": { "type": "string", "minLength": 1 },
          "desktopPollIntervalMs": {
            "type": "integer",
            "minimum": 250,
            "maximum": 60000
          },
          "desktopStatePath": { "type": "string", "minLength": 1 },
          "desktopOutboundEnabled": { "type": "boolean" },
          "desktopOutboundSwitchPath": { "type": "string", "minLength": 1 },
          "desktopMediaRoots": {
            "type": "array",
            "maxItems": 16,
            "items": { "type": "string", "minLength": 1 }
          },
          "desktopAckMode": {
            "type": "string",
            "enum": ["off", "typing", "message"],
            "description": "Immediate acknowledgement after validated, deduplicated desktop inbound; defaults to off"
          },
          "desktopAckText": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "description": "Text acknowledgement and fallback when native typing is unavailable"
          },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "mode": { "type": "string", "enum": ["botx", "desktop"] },
                "botId": { "type": "string" },
                "secretKey": { "type": "string" },
                "ctsUrl": { "type": "string" },
                "markdown": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "tables": {
                      "type": "string",
                      "enum": ["off", "code", "block", "bullets"]
                    }
                  }
                },
                "actions": {
                  "type": "object",
                  "additionalProperties": {
                    "anyOf": [
                      { "type": "boolean" },
                      {
                        "type": "string",
                        "enum": ["pairing", "allowlist", "open"]
                      }
                    ]
                  }
                },
                "webhookPort": { "type": "integer", "minimum": 1 },
                "dmPolicy": {
                  "type": "string",
                  "enum": ["pairing", "allowlist", "open", "disabled"]
                },
                "allowFrom": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "streamMode": {
                  "type": "string",
                  "enum": ["off", "partial", "block"]
                },
                "mediaMaxMb": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 100
                },
                "textChunkLimit": { "type": "integer", "minimum": 1 },
                "desktopCdpUrl": { "type": "string" },
                "desktopChatId": { "type": "string", "format": "uuid" },
                "desktopChatTitle": { "type": "string", "minLength": 1 },
                "desktopSenderId": { "type": "string", "format": "uuid" },
                "desktopSenderName": { "type": "string", "minLength": 1 },
                "desktopPollIntervalMs": {
                  "type": "integer",
                  "minimum": 250,
                  "maximum": 60000
                },
                "desktopStatePath": { "type": "string", "minLength": 1 },
                "desktopOutboundEnabled": { "type": "boolean" },
                "desktopOutboundSwitchPath": {
                  "type": "string",
                  "minLength": 1
                },
                "desktopMediaRoots": {
                  "type": "array",
                  "maxItems": 16,
                  "items": { "type": "string", "minLength": 1 }
                },
                "desktopAckMode": {
                  "type": "string",
                  "enum": ["off", "typing", "message"]
                },
                "desktopAckText": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {}
}
